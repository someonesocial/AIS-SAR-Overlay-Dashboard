# API Configuration
# Get your free API key from https://aisstream.io
AISSTREAM_API_KEY=yourAPIkeyHere
# Temporary dev-only workaround if aisstream.io serves an expired certificate.
# Keep false unless you specifically see "certificate has expired".
AISSTREAM_ALLOW_INSECURE_TLS=false

# Backend API URL (for production, leave empty for same-origin)
#VITE_API_URL=
#VITE_WS_URL=

# NASA ASF Credentials (optional - for enhanced SAR data access)
# ASF_USERNAME=your_asf_username
# ASF_PASSWORD=your_asf_password
